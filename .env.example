########################################
# AURA - environment configuration
# Copy to .env and fill in values.
########################################

# --- Gemini ---
# Get one from https://aistudio.google.com/app/apikey
AURA_GEMINI_API_KEY=
AURA_GEMINI_FAST_MODEL=gemini-2.0-flash
AURA_GEMINI_REASONING_MODEL=gemini-2.0-pro

# --- Postgres ---
POSTGRES_DB=aura
POSTGRES_USER=aura
POSTGRES_PASSWORD=aura

# --- Auth ---
# 32+ character random string. Generate with: openssl rand -hex 32
AURA_JWT_SECRET=change-me-in-production-please-32chars

# --- Gateway ---
AURA_CORS_ORIGINS=http://localhost:3000
AURA_RATE_LIMIT_RPS=20

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8081
NEXT_PUBLIC_WS_URL=ws://localhost:8081
